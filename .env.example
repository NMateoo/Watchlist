# Copia este archivo a ".env" y rellena tus valores.

# Token del bot: créalo hablando con @BotFather en Telegram (/newbot)
TELEGRAM_BOT_TOKEN=

# Tu chat: mándale un mensaje al bot y la página /settings te dirá tu chat_id
TELEGRAM_CHAT_ID=

# Opcionales (valores por defecto):
# CHECK_INTERVAL_MINUTES=10
# DAILY_SUMMARY_TIME=22:10
# TIMEZONE=Europe/Madrid
# MOVE_ALERT_THRESHOLD=5
# DATABASE_URL=sqlite:///watchlist.db   (en Render: URL de Postgres de Neon)
